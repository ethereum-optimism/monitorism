{
  "shared_paths": [
    ".github/workflows/branches.yaml",
    ".github/images.json",
    "docker-bake.hcl"
  ],
  "images": {
    "op-monitorism": {
      "mode": "bake",
      "bake_file": "docker-bake.hcl",
      "target": "op-monitorism",
      "paths": ["op-monitorism/**"]
    },
    "op-defender": {
      "mode": "bake",
      "bake_file": "docker-bake.hcl",
      "target": "op-defender",
      "paths": ["op-defender/**"]
    }
  }
}
