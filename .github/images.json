{
  "shared_paths": [
    ".github/workflows/factory.yaml",
    ".github/images.json"
  ],
  "images": {
    "op-monitorism": {
      "mode": "ko",
      "ko_working_directory": "op-monitorism",
      "ko_importpath": "./cmd/monitorism",
      "env": "VERSION=v0.0.0",
      "paths": ["op-monitorism/**"]
    },
    "op-defender": {
      "mode": "ko",
      "ko_working_directory": "op-defender",
      "ko_importpath": "./cmd/defender",
      "env": "VERSION=v0.0.0",
      "paths": ["op-defender/**"]
    }
  }
}
